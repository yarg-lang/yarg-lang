var s1 = clock();
print "Add";
for (var i = 0; i < 500; i = 1 + i) for (var j = 0; j < 500; j = 1 + j) for (var k = 0; k < reps_addsub; k = 1 + k)
{
    rts[i] + rts[j];
}
var t = clock() - s1;
var ti = 10000000 * int(t);
ti = ti / 500 / 500 / reps_addsub;
print string(ti / 1000) + "." + string (ti % 1000) + " ms / add";

s1 = clock();
print "Sub";
for (var i = 0; i < 500; i = 1 + i) for (var j = 0; j < 500; j = 1 + j) for (var k = 0; k < reps_addsub; k = 1 + k)
{
    rts[i] - rts[j];
}
t = clock() - s1;
ti = 10000000 * int(t);
ti = ti / 500 / 500 / reps_addsub;
print string(ti / 1000) + "." + string (ti % 1000) + " ms / sub";

s1 = clock();
print "Mul";
for (var i = 0; i < reps_mul; i = 1 + i) for (var j = 500 - reps_mul; j < 500; j = 1 + j)
{
    rts[i] * rts[j];
}
t = clock() - s1;
ti = 10000000 * int(t);
ti = ti / reps_mul / reps_mul;
print string(ti / 1000) + "." + string (ti % 1000) + " ms / mul";

const zint = int(0);
s1 = clock();
print "Div";
for (var i = 0; i < reps_div; i = 1 + i) for (var j = 500 - reps_div; j < 500; j = 1 + j)
{
    if (rts[j] != zint)
    {
        rts[i] / rts[j];
    }
    else
    {
        print string(i) + " " + string(rts[i]);
        print "/ " + string(j) + " " + string(rts[j]);
    }
}
t = clock() - s1;
ti = 10000000 * int(t);
ti = ti / reps_div / reps_div;
print string(ti / 1000) + "." + string (ti % 1000) + " ms / div";
