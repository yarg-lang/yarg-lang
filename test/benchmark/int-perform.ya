var int32 job_size = 100;
var max_job_length = 10;

// https://github.com/kraj/uClibc/blob/master/libc/stdlib/rand_r.c#L25
var maxRand = uint32(0x7fffffff);
var uint32 seed = 173993;
fun rand()
{
    var uint32 next = seed;
    var uint32 result;

    next = next * 1103515245;
    next = next + 12345;
    result = (next / 65536) % 2048;

    next = next * 1103515245;
    next = next + 12345;
    result = result << 10;
    result = result ^ ((next / 65536) % 1024);

    next = next * 1103515245;
    next = next + 12345;
    result = result << 10;
    result = result ^ ((next / 65536) % 1024);

    seed = next;
    return next & maxRand;
}

fun int_rand()
{
    var shifter = 0x80000000;
    var size = int(rand() % uint32(33)); // max 33 * 31 => 1023 bits
    var int x = int(rand());

    for (var i = 0; i < size; i = 1 + i)
    {
        x = x * shifter + int(rand());
    }

    if (size == 32)
    {
        if (rand() % uint32(2) == uint32(1))
        {
            x = x + ;
        }
    }

    if (rand() % uint32(2) == uint32(1))
    {
        return -x;
    }
    else
    {
        return x;
    }
}

var int[job_size] rts;
print "int-perform benchmark: job size: " + string(job_size) + ", max job length: " + string(max_job_length) + "secs";

var int32 count = 0;
var int32 rand_calls = 0;
while (count < int32(job_size)) {
    var candidate = int_rand();
    rand_calls = rand_calls + 1;
    if (candidate != 0) {
        rts[count] = candidate;
        count = count + 1;
    }
}
print "Generated " + string(job_size) + " non-zero random numbers in " + string(rand_calls) + " calls to int_rand()";

fun add_job(i, n) {
    for (var int32 j = 0; j < n; j = 1 + j)
    {
        rts[i] + rts[j];
    }
}

fun sub_job(i, n) {
    for (var int32 j = 0; j < n; j = 1 + j)
    {
        rts[i] - rts[j];
    }
}

fun mul_job(i, n) {
    for (var int32 j = 0; j < n; j = 1 + j)
    {
        rts[i] * rts[j];
    }
}

fun div_job(i, n) {
    for (var int32 j = 0; j < n; j = 1 + j)
    {
        rts[i] / rts[j];
    }
}

fun mod_job(i, n) {
    for (var int32 j = 0; j < n; j = 1 + j)
    {
        rts[i] % rts[j];
    }
}

fun negate_job(i, n) {
    for (var int32 j = 0; j < n; j = 1 + j)
    {
        -rts[i];
    }
}

fun bench_job(job_size, op_job, limit) {
    int32 jobs = 0;
    while (int(clock()) < limit) {
        for (var int32 i = 0; i < job_size; i = 1 + i)
        {
            op_job(i, job_size);
            jobs = jobs + 1;
            if (int(clock()) > limit) {
                return i * job_size * jobs;
            }
        }
    }
    return job_size * job_size * jobs;
}

fun bench_op(name, batch_fun) {
    var start_time = int(clock());
    var total_ops = int(bench_job(job_size, batch_fun, start_time + max_job_length));
    var time_taken = int(clock()) - start_time;
    var ops_per_ms = total_ops / (1000 * time_taken);
    print name + " time: " + string(time_taken) + "secs, ops: " + string(total_ops) + ", "  + string(ops_per_ms) + "ops/ms";
}

bench_op("Add (x+y)", add_job);
bench_op("Sub (x-y)", sub_job);
bench_op("Mul (x*y)", mul_job);
bench_op("Div (x/y)", div_job);
bench_op("Mod (x%y)", mod_job);
bench_op("Negate (-x)", negate_job);
