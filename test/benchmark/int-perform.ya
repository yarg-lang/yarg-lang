const reps_addsub = 90;
const reps_mul = 500;
const reps_div = 500;

// https://github.com/kraj/uClibc/blob/master/libc/stdlib/rand_r.c#L25
const maxRand = uint32(0x7fffffff);
var uint32 seed = 173993;
fun rand()
{
    var uint32 next = seed;
    var uint32 result;

    next = next * 1103515245;
    next = next + 12345;
    result = (next / 65536) % 2048;

    next = next * 1103515245;
    next = next + 12345;
    result = result << 10;
    result = result ^ ((next / 65536) % 1024);

    next = next * 1103515245;
    next = next + 12345;
    result = result << 10;
    result = result ^ ((next / 65536) % 1024);

    seed = next;
    return next & maxRand;
}

const shifter = 0x80000000;
var temp = new(int[4]);
fun int_rand()
{
    const size = int(rand() % uint32(33)); // max 33 * 31 => 1023 bits
    var int x = int(rand());

    for (var i = 0; i < size; i = 1 + i)
    {
        x = x * shifter + int(rand());
    }

    if (size == 32)
    {
        if (rand() % uint32(2) == uint32(1))
        {
            x = x + ;
        }
    }

    if (rand() % uint32(2) == uint32(1))
    {
        return -x;
    }
    else
    {
        return x;
    }
}

var rts = new(int[500]);
const zint = int(0);

for (var x = 0; x < 500; x = 1 + x)
{
    var i = int_rand();
    if (i == zint)
    {
        print string(x) + " " + string(i);
    }
    rts[x] = i;
}

