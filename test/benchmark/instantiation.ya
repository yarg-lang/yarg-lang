// This benchmark stresses instance creation and initializer calling.
var iterations = 5000;
print "instantiation: iterations: " + string(iterations);

class Foo {
  init() {}
}

var begin = int(clock());
var i = 0;
while (i < iterations) {
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  Foo();
  i = i + 1;
}

var elapsed = int(clock()) - begin;
print "Time: " + string(elapsed);
