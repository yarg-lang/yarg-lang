//test_interrupt(5);
//test_interrupt(6);
//test_interrupt(7);
//test_interrupt(5);
//test_interrupt("PIO0_IRQ_1");

test_interrupt("USBCTRL_IRQ");
test_interrupt("TIMER_IRQ_2");
test_interrupt("TIMER_IRQ_3");
test_interrupt("USBCTRL_IRQ");

var result = 30 - 1;
//var results = new(any[result + 1]);
while (result >= 0)
{
    test_sync();
//    results[result] = test_sync();
    result = result - 1;


    var uint32 t = 0;
    for (var i = 0; i < len(interrupts); i = 1 + i)
    {
        while (cpeek(interrupts[i][1]) != nil)
        {
            var m = receive(interrupts[i][1]);
            t = t + m;
        }
    }
    print "t:" + string(t);

    t = t - 1;
    for (var b = 0; b < len(interrupts); b = 1 + b)
    {
        if (t & 1 == 1)
        {
            test_interrupt(b + 1);
        }
        t = t >> 1;
    }
}

for (var i = 0; i < len(interrupts); i = i + 1)
{
    irq_remove_handler(1, interrupts[i][0]);
}

