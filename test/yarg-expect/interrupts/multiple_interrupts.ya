
fun setup_interrupt(number) {
    var name = "handler" + string(number);
    var chan = make_channel();
    var p = uint32(1) << uint32(number - 1);

    fun handler() {
//        print name;
        send(chan, p);
    }

    var handler_routine = make_routine(handler);
    var handler_address = pin(handler_routine);
    irq_add_shared_handler(number, handler_address, 1);

    return [handler_address, chan];
}

var interrupts = new(any[8]);

for (var i = 0; i < len(interrupts); i = i + 1)
{
    interrupts[i] = setup_interrupt(1 + i);
}

//test_interrupt("TIMER_IRQ_1");
//test_interrupt(2);
//test_interrupt(3);
