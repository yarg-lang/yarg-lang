var test = ["test": 10, "ME": "JOHN"];
print test["test"]; // expect: 10
print test["ME"]; // expect: JOHN
print len(test); // expect: 2
var heapMap = new(any[string]);
heapMap["answer"] = 42;
print heapMap["answer"]; // expect: 42

