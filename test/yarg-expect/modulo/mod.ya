print 5 % 10; // expect: 5
print 10 % 6; // expect: 4
// this is python % not c % (which would give -1)
print -1 % 3; // expect: 2

print 3 % 8; // expect: 3
print -3 % 8; // expect: 5
print 3 % -8; // expect: -5
print -3% -8; // expect: -3
print 9 % 8; // expect: 1
print -9 % 8; // expect: 7
print 9 % -8; // expect: -7
print -9 % -8; // expect: -1
print 0 % 8; // expect: 0
print 0 % -8; // expect: 0


print int8(3) % int8(8); // expect: 3
print int8(-3) % int8(8); // expect: 5
print int8(3) % int8(-8); // expect: -5
print int8(-3) % int8(-8); // expect: -3
print int8(9) % int8(8); // expect: 1
print int8(-9) % int8(8); // expect: 7
print int8(9) % int8(-8); // expect: -7
print int8(-9) % int8(-8); // expect: -1
print int8(0) % int8(8); // expect: 0
print int8(0) % int8(-8); // expect: 0

print int16(3) % int16(8); // expect: 3
print int16(-3) % int16(8); // expect: 5
print int16(3) % int16(-8); // expect: -5
print int16(-3) % int16(-8); // expect: -3
print int16(9) % int16(8); // expect: 1
print int16(-9) % int16(8); // expect: 7
print int16(9) % int16(-8); // expect: -7
print int16(-9) % int16(-8); // expect: -1
print int16(0) % int16(8); // expect: 0
print int16(0) % int16(-8); // expect: 0

print int32(3) % int32(8); // expect: 3
print int32(-3) % int32(8); // expect: 5
print int32(3) % int32(-8); // expect: -5
print int32(-3) % int32(-8); // expect: -3
print int32(9) % int32(8); // expect: 1
print int32(-9) % int32(8); // expect: 7
print int32(9) % int32(-8); // expect: -7
print int32(-9) % int32(-8); // expect: -1
print int32(0) % int32(8); // expect: 0
print int32(0) % int32(-8); // expect: 0

print int64(3) % int64(8); // expect: 3
print int64(-3) % int64(8); // expect: 5
print int64(3) % int64(-8); // expect: -5
print int64(-3) % int64(-8); // expect: -3
print int64(9) % int64(8); // expect: 1
print int64(-9) % int64(8); // expect: 7
print int64(9) % int64(-8); // expect: -7
print int64(-9) % int64(-8); // expect: -1
print int64(0) % int64(8); // expect: 0
print int64(0) % int64(-8); // expect: 0

print 1.0 % 2.0; // expect runtime error: Operands must integers or unsigned integers of same type.

