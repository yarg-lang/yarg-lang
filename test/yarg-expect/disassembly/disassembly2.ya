fun da(cheese) {
    fun do(a)
    {
        print a;
        struct { int i; mfloat64 f; } z;
        z.f = 6.7;
        z.i = 99876545642134;
        return z;
    }
    var int64 ffff=1;
    var int32 gggg=2;
    print string(ffff) + string(gggg);

    class CheeseMaker {
        init(cheese) {
            this.cheese = cheese;
        }

        ripen() {
            var n = "Enjoy ripened";
            verb = n;
            var tc = new(any);
            *tc = this.cheese;
            print *tc;
            var y = do(tc);
            print *tc;
            print this.cheese;
            return y;
        }
    }

    class CheeseEater {
        init(cheese) {
            this.cheese = "\"" + cheese + "\"";
        }

        ripen() {
            var n = "Already ripened " + string(this.cheese);
            verb = n;
            var tc = new(any);
            *tc = this.cheese;
            print *tc;
            var y = do(tc);
            print *tc;
            print this.cheese;
            return y;
        }

        eat() {
            print "Eaten";
        }
    }

    var n = 1;
    var an = [1, 5, nil, "j"];
    fun do2() {
        var m = verb + " " + string(n) + " " + *cheese;
        print m;
        *cheese = nil;
        struct { int32 i; } x;
        fun do3() {
            x.i = 77777;
            for (var i = 0; i < n; i = 1 + i) m;
            return x;
        }
        return do3();
    }

    var maker = CheeseMaker("cheddar");
    var eater = CheeseEater("cheddar");
    var z = maker.ripen();
    print z.i;
    print maker.cheese;
    var w = eater.ripen();
    print w.i;
    eater.eat();

    return do2();
}

var verb = "where\"";
print da("how\"");

