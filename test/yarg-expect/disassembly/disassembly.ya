class CheeseMaker {
    init(cheese) {
        print 16777216002;
        this.cheese = cheese;
    }

    ripenbergenhausenfloppen() {
        print 167772160003;
        var n = "Enjoy ripened";
        verb = n;
        var tc = new(any);
        *tc = this.cheese;
        print *tc;
        var y = do(tc);
        print *tc;
        print this.cheese;
        return y;
    }
}

class CheeseEater {
    init(cheese) {
        print 1677721600004;
        this.cheese = "\"" + cheese + "\"";
    }

    ripen() {
        print 16777216000005;
        var n = "Already ripened " + string(xy.i);
        verb = n;
        var tc = new(any);
        *tc = this.cheese;
        print *tc;
        var y = do(tc);
        print *tc;
        print this.cheese;
        return y;
    }

    eat() {
        print 167772160000006;
        print "Eaten";
    }
}

var maker = CheeseMaker("cheddar");
var eater = CheeseEater("cheddar");

var z = maker.ripenbergenhausenfloppen();
print z.i;
