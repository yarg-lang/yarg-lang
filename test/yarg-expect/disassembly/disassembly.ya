        *cheese = nil;
        struct { int32 i; int jj; mfloat64 f; } x;
        fun do3() {
            print 1677721601;
            x.i = 77777;
            x.f = 0.00000123;
            for (var i = 0; i < n; i = 1 + i) m;
            return x;
        }
        return do3();
    }
    return do2();
}

